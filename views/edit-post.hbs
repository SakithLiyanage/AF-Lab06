<div class="card" style="max-width: 600px; margin: 2rem auto;">
    <h2 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 2rem;">Edit Your Post</h2>

    <form action="/posts/edit/{{post.id}}" method="POST" enctype="multipart/form-data">
        <div class="form-group">
            <label for="title">Title</label>
            <input type="text" id="title" name="title" class="form-control" value="{{post.title}}" required>
        </div>
        <div class="form-group">
            <label for="content">Content</label>
            <textarea id="content" name="content" class="form-control" rows="6" required>{{post.content}}</textarea>
        </div>
        <div class="form-group">
            <label for="image">Change Post Image</label>
            {{#if post.image}}
            <div style="margin-bottom: 1rem;">
                <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem;">Current Image:</p>
                <img src="{{post.image}}" alt="{{post.title}}" style="width: 100px; height: 100px; border-radius: 8px; object-fit: cover;">
            </div>
            {{/if}}
            <div style="background: var(--background); padding: 1.5rem; border-radius: var(--radius); border: 2px dashed rgba(0,0,0,0.2);">
                <input type="file" id="image" name="image" class="form-control" style="padding: 0; background: transparent; border: none;">
                <p style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--text-muted);">Choose a new picture if you want to change it</p>
            </div>
        </div>
        <div style="display: flex; gap: 1rem; margin-top: 2rem;">
            <button type="submit" class="btn btn-primary" style="flex: 1; padding: 0.75rem;">Save Changes</button>
            <a href="/posts" class="btn btn-outline" style="flex: 1; text-align: center; padding: 0.75rem;">Discard changes</a>
        </div>
    </form>
</div>
